# true: frontend uses built-in demo data and backend is not required
USE_MOCK_API=true

# Set USE_MOCK_API=false to use the real API
API_BASE_URL=http://localhost:8000/api/v1

# Flask API listener used by `python -m src.api`.
API_HOST=127.0.0.1
API_PORT=8000
FLASK_DEBUG=false

# Local development. Production should use a secret-managed database URL.
DATABASE_URL=sqlite:///data/app.sqlite3
AUTO_CREATE_DB=true
DEFAULT_USER_ID=local-demo

# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/risk_intelligence
# AUTO_CREATE_DB=false

# Reload HTML/CSS/JS automatically while editing. Disable in production.
DEV_AUTO_RELOAD=true

# Backend-only examples for the future large-model client.
# Exact names may be changed to match the selected provider.
# MODEL_API_KEY=replace_me
# MODEL_BASE_URL=https://provider.example/v1
# MODEL_NAME=selected-large-model
