FORBIDDEN_TABLES=["users", "authentications", "alerts", "subscriptions"]
DB_DRIVER=postgresql+
# внутри docker compose бэкенд ходит в сервис postgres;
# для запуска вне докера поменяйте на localhost
DB_HOST=postgres
DB_PORT=5432
DB_NAME=siriusgpb
DB_USER=postgres
DB_PASSWORD=postgres

POSTGRES_DB=siriusgpb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Ключ DeepSeek (клиент OpenAI-совместимый). Без ключа RAG работает
# в режиме retrieval_only: находит новости, но не генерирует ответ.
OPENAI_API_KEY=sk-095c26217efa4934943e33475199f60b

# Внешний RAG-сервис (ai_handler). Если не запущен — бэкенд использует
# встроенный поиск по новостям + DeepSeek напрямую.
AI_HANDLER_URL=http://ai_handler:8088